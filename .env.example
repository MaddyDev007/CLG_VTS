# Copy this file to .env before a real EC2 deployment.
# The compose file reads these values during build and startup.

# Public HTTP entrypoint
FRONTEND_BIND_ADDRESS=0.0.0.0
FRONTEND_PORT=80

# Optional simulator UI/API host binding.
# 0.0.0.0 keeps localhost access working and also allows EC2/public-IP access
# when port 3011 is permitted by the host firewall or AWS security group.
SIMULATOR_BIND_ADDRESS=0.0.0.0
SIMULATOR_PORT=3011

# Frontend build-time URLs. Same-origin defaults work with the nginx reverse proxy.
VITE_API_BASE_URL=/api
VITE_WS_URL=/telemetry
VITE_DEVICE_SIMULATOR_URL=
VITE_MQTT_TOPIC_PREFIX=vts

# Small-instance build safety
FRONTEND_NODE_OPTIONS=--max-old-space-size=512
SIMULATOR_NODE_OPTIONS=--max-old-space-size=384

# Database and backend secrets
POSTGRES_IMAGE_TAG=15-alpine
POSTGRES_DB=vts
POSTGRES_USER=postgres
DB_PASSWORD=change-me-db-password
JWT_SECRET=change-me-long-random-secret

# Optional broker auth
MQTT_USERNAME=
MQTT_PASSWORD=

# Optional backend overrides
CORS_ORIGINS=http://your-ec2-public-hostname
TEMPORAL_ENABLED=false
TEMPORAL_ADDRESS=
REDIS_URL=
