# for public release
MQTT_BROKER_URL=mqtt://localhost:1883
POSTGRES_URL=postgres://postgres:vts123@localhost:5432/vts

SIM_PROTOCOL=mqtt

SIM_TCP_HOST=localhost
SIM_TCP_PORT=4002

SIM_UDP_HOST=localhost
SIM_UDP_PORT=4001

SIM_INTERVAL_MS=5000
MODE=random

DEVICE_COUNT=5
DEVICE_PREFIX=sim_device_
MIN_SPEED=0
MAX_SPEED=80