# Required
NODE_ENV=development
PORT=3000
JWT_SECRET=change-me
JWT_EXPIRES_IN=1d

# API routing
API_PREFIX=
WS_NAMESPACE=/telemetry

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vts
DB_USER=postgres
DB_PASSWORD=vts123

# MQTT
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TELEMETRY_TOPIC=vts/+/telemetry

# Optional ingestion listeners
UDP_PORT=4001
TCP_PORT=4002
TCP_HOST=0.0.0.0

# Optional runtime dependencies
TEMPORAL_ENABLED=false
TEMPORAL_ADDRESS=
TELEMETRY_STATE_STORE=memory
REDIS_URL=
REDIS_STATE_TTL_SECONDS=604800

# Browser origins for local dev only
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3011,http://127.0.0.1:3011
